# Set ARRP_INTAKE_MODE=live only after every required setting is configured.
ARRP_INTAKE_MODE=preview

# Comma-separated origins permitted to submit, without trailing slashes.
# Example: https://thorncrag.github.io,https://arrp.example.org
ARRP_ALLOWED_ORIGINS=

# Cloudflare Turnstile: site key is public; secret key stays only in Vercel.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# GitHub App credentials. Grant only Discussions: Read & write for Thorncrag/ARRP.
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nreplace-with-key\n-----END RSA PRIVATE KEY-----"
GITHUB_REPOSITORY_ID=
GITHUB_DISCUSSION_CATEGORY_ID=

# Optional transactional email. Leave both blank to omit email delivery.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
