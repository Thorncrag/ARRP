# Set ARRP_INTAKE_MODE=live only after every required setting is configured.
ARRP_INTAKE_MODE=preview
# Emergency full-service pause: set to paused and redeploy Production.
# ARRP_INTAKE_MODE=paused

# Emergency contact-only pause: set to disabled and redeploy Production.
ARRP_CONTACT_MODE=live

# Comma-separated origins permitted to submit, without trailing slashes.
# Example: https://thorncrag.github.io,https://arrp.example.org
ARRP_ALLOWED_ORIGINS=

# Cloudflare Turnstile: site key is public; secret key stays only in Vercel.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Match the public production hostname exactly. The action is checked server-side
# to reject tokens minted for another purpose.
ARRP_TURNSTILE_HOSTNAME=arrp-public-intake.vercel.app
ARRP_TURNSTILE_ACTION=arrp_public_intake

# GitHub App credentials. Grant only Discussions: Read & write for Thorncrag/ARRP.
GITHUB_APP_ID=
GITHUB_APP_INSTALLATION_ID=
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nreplace-with-key\n-----END RSA PRIVATE KEY-----"
GITHUB_REPOSITORY_ID=
GITHUB_DISCUSSION_CATEGORY_ID=

# Private author contact and optional owner notification. The current design
# never sends email to a contributor.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
# Private mailbox for messages sent through the Contact the author route.
ARRP_CONTACT_EMAIL=
# Optional legacy fallback for notices of public-input contributors who authorize follow-up.
ARRP_INTAKE_REVIEW_EMAIL=
