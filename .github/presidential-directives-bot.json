{
  "schemaVersion": 2,
  "enabled": true,
  "botName": "presidential-directives-bot",
  "catalogPath": "inventory/presidential-directives.csv",
  "automation": {
    "branch": "automation/presidential-directives-monitor",
    "assignee": "Thorncrag",
    "eventProjection": "project-console-data:run-chain.json"
  },
  "schedule": {
    "mode": "run-chain",
    "coordinator": ".github/workflows/run-coordinator-bot.yml",
    "dueEveryHours": 24
  },
  "provider": {
    "type": "federal-register-api-v1",
    "apiRoot": "https://www.federalregister.gov/api/v1",
    "allowedHosts": [
      "www.federalregister.gov"
    ],
    "presidentialDocumentType": "PRESDOCU",
    "pageSize": 1000,
    "maxPagesPerQuery": 20
  },
  "scope": [
    {
      "administration": "Trump I",
      "presidentIdentifier": "donald-trump",
      "presidentName": "Donald Trump",
      "signedOnOrAfter": "2017-01-20",
      "signedOnOrBefore": "2021-01-19"
    },
    {
      "administration": "Biden",
      "presidentIdentifier": "joe-biden",
      "presidentName": "Joseph R. Biden Jr.",
      "signedOnOrAfter": "2021-01-20",
      "signedOnOrBefore": "2025-01-19"
    },
    {
      "administration": "Trump II",
      "presidentIdentifier": "donald-trump",
      "presidentName": "Donald Trump",
      "signedOnOrAfter": "2025-01-20"
    }
  ]
}
