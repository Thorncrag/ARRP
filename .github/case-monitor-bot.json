{
  "schemaVersion": 6,
  "enabled": true,
  "botName": "case-monitor-bot",
  "sourceMonitoringField": "Monitoring",
  "sourceBaselineField": "Monitoring Baseline",
  "tracker": {
    "type": "just-security-litigation-tracker",
    "url": "https://www.justsecurity.org/107087/tracker-litigation-legal-challenges-trump-administration/",
    "allowedHosts": [
      "www.justsecurity.org"
    ],
    "tableId": "tablepress-42",
    "minimumEntries": 500,
    "maximumEntries": 2500,
    "maximumResponseBytes": 10000000
  },
  "verification": {
    "type": "courtlistener-rest-v4",
    "apiRoot": "https://www.courtlistener.com/api/rest/v4",
    "allowedHosts": [
      "www.courtlistener.com"
    ],
    "maxDocketsPerRun": 20,
    "requestIntervalSeconds": 13
  },
  "sourceDevelopmentModules": [
    {
      "moduleId": "judicial-review-disposition-signals",
      "recordId": "HOR-035",
      "enabled": true,
      "targetPath": "research/horizon-source-records/HOR-035-source-development.md",
      "insertBeforeHeading": "## General source development",
      "maximumLeads": 250,
      "matchFields": [
        "status",
        "case_summary",
        "case_updates"
      ],
      "signalGroups": [
        {
          "id": "mootness",
          "terms": [
            "moot",
            "mootness",
            "voluntary cessation"
          ]
        },
        {
          "id": "withdrawal-or-rescission",
          "terms": [
            "withdraw",
            "withdrawn",
            "withdrawal",
            "rescind",
            "rescinded",
            "rescission"
          ]
        },
        {
          "id": "replacement-or-supersession",
          "terms": [
            "replace",
            "replaced",
            "replacement",
            "supersede",
            "superseded",
            "superseding"
          ]
        },
        {
          "id": "settlement-or-stipulated-dismissal",
          "terms": [
            "settle",
            "settled",
            "settlement",
            "stipulation of dismissal",
            "stipulated dismissal"
          ]
        },
        {
          "id": "vacatur",
          "supplemental": true,
          "terms": [
            "vacate",
            "vacated",
            "vacatur",
            "munsingwear"
          ]
        }
      ]
    }
  ],
  "automation": {
    "branch": "bot/case-monitor-updates",
    "baseBranch": "main",
    "assignee": "Thorncrag",
    "pullRequestTitle": "Case-monitor source updates",
    "eventProjection": "project-console-data:run-chain.json"
  },
  "schedule": {
    "mode": "run-chain",
    "coordinator": ".github/workflows/run-coordinator-bot.yml",
    "dueEveryHours": 24
  }
}
