<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.thorncrag.arrp-run-coordinator</string>
  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/python3</string>
    <string>/Users/benjaminsmith/Documents/ARRP/scripts/run_chain_dispatcher.py</string>
    <string>--launch-codex</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/Users/benjaminsmith/Documents/ARRP</string>
  <key>StartInterval</key>
  <integer>600</integer>
  <key>StandardOutPath</key>
  <string>/Users/benjaminsmith/Documents/ARRP/.tmp/run-coordinator/launchd.out.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/benjaminsmith/Documents/ARRP/.tmp/run-coordinator/launchd.err.log</string>
</dict>
</plist>
